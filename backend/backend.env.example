# ═══════════════════════════════════════════════════
# TechPigeon Backend — Environment Variables
# ═══════════════════════════════════════════════════
NODE_ENV=development
PORT=5000

# ── PostgreSQL (Neon.tech) ──────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/techpigeon?sslmode=require

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# ── Frontend URL (for CORS + email links) ──────────
FRONTEND_URL=https://techpigeon-com-pk-frontend1.vercel.app
FRONTEND_URL_ALT=https://www.techpigeon-com-pk-frontend1.vercel.app
FRONTEND_PREVIEW_URL=https://techpigeon-com-pk-frontend1.vercel.app

# ── Email (Resend / SMTP) ──────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxx
EMAIL_FROM=noreply@techpigeon.org

# ── Stripe ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ── JazzCash ───────────────────────────────────────
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_URL=https://sandbox.jazzcash.com.pk/ApplicationAPI/API/Payment/DoTransaction

# ── EasyPaisa ──────────────────────────────────────
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_URL=https://easypay.easypaisa.com.pk/easypay/Index.jsf
